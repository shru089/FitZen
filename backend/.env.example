# ─── Sanctuary Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# Database (leave as SQLite for local dev; switch to PostgreSQL for production)
DATABASE_URL=sqlite:///./sanctuary.db
# DATABASE_URL=postgresql://user:password@localhost:5432/sanctuary_db

# JWT — CHANGE THIS to a long random string in production!
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sanctuary_super_secret_key_change_in_prod_2024
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
